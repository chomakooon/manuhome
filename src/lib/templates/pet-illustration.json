{
    "id": "pet-illustration-service",
    "name": "ペットイラスト・グッズ制作",
    "description": "大切なペットをイラストに。アクリルスタンドやステッカーなどグッズ制作も対応します",
    "version": "2.0.0",
    "tiers": [
        {
            "id": "GOODS_DATA_ONLY",
            "name": "イラストデータのみ",
            "description": "デジタルイラスト1枚（PNG + JPG）。納期7日。",
            "price": 5000,
            "features": ["digital illustration x1", "delivery: PNG + JPG", "long edge 3000px", "revisions: 1"]
        },
        {
            "id": "GOODS_STICKER",
            "name": "ステッカーシート",
            "description": "イラスト + ステッカーシート1枚（A6サイズ）。納期10日。",
            "price": 6000,
            "features": ["digital illustration x1", "sticker sheet A6 x1", "delivery: product + PNG", "revisions: 1"]
        },
        {
            "id": "GOODS_ACRYLIC_STAND",
            "name": "アクリルスタンド",
            "description": "イラスト + アクリルスタンド1個（高さ約8cm）。納期14日。",
            "price": 8000,
            "features": ["digital illustration x1", "acrylic stand x1", "height ~8cm", "delivery: product + PNG", "revisions: 1"]
        },
        {
            "id": "GOODS_MUG",
            "name": "マグカップ",
            "description": "イラスト + オリジナルマグカップ1個。納期14日。",
            "price": 9000,
            "features": ["digital illustration x1", "mug x1", "delivery: product + PNG", "revisions: 1"]
        },
        {
            "id": "GOODS_TSHIRT",
            "name": "Tシャツ",
            "description": "イラスト + オリジナルTシャツ1枚。納期14日。",
            "price": 10000,
            "features": ["digital illustration x1", "T-shirt x1", "size: S/M/L/XL", "delivery: product + PNG", "revisions: 1"]
        },
        {
            "id": "GOODS_SET",
            "name": "グッズセット",
            "description": "イラスト + アクリルスタンド + ステッカー。納期14日。",
            "price": 12800,
            "features": ["digital illustration x1", "acrylic stand x1", "sticker sheet x1", "delivery: products + PNG + JPG", "revisions: 2"]
        }
    ],
    "options": [
        {
            "id": "EXTRA_PET",
            "name": "ペット追加",
            "price": 3000,
            "description": "1匹追加ごとに+3,000円"
        },
        {
            "id": "BACKGROUND_CUSTOM",
            "name": "背景指定",
            "price": 1500,
            "description": "お好きな背景を指定"
        },
        {
            "id": "TEXT_LABEL",
            "name": "文字入れ",
            "price": 500,
            "description": "お名前や日付などをデザインに含める"
        },
        {
            "id": "PSD_SOURCE",
            "name": "PSDデータ納品",
            "price": 3000,
            "description": "編集可能なPSDデータもお渡し"
        },
        {
            "id": "EXPRESS_DELIVERY",
            "name": "お急ぎ納品",
            "price": 4000,
            "description": "優先して制作し、納期を約半分に短縮（※対応可能な場合のみ）",
            "toggleableByCreator": true
        }
    ],
    "formSteps": [
        {
            "step": 1,
            "id": "step_photo",
            "name": "写真アップロード",
            "type": "asset_upload",
            "minFiles": 1,
            "maxFiles": 8,
            "validationRules": [
                "ペットの顔がはっきり写っている写真をお送りください",
                "暗い写真・ぼやけた写真・逆光の写真は避けてください",
                "複数アングルの写真があると、より似た仕上がりになります"
            ],
            "consentRequired": [
                "制作に必要な場合、追加の写真をお願いすることがあります"
            ]
        },
        {
            "step": 2,
            "id": "step_style_select",
            "name": "画風の選択",
            "type": "custom_fields",
            "fields": [
                {
                    "id": "art_style",
                    "label": "お好みの画風をお選びください",
                    "type": "select",
                    "options": [
                        {
                            "label": "ふんわり水彩",
                            "value": "watercolor",
                            "icon": "Palette",
                            "description": "透明感のある水彩タッチ。柔らかく優しい仕上がり"
                        },
                        {
                            "label": "ポップ＆カラフル",
                            "value": "pop",
                            "icon": "Sparkles",
                            "description": "鮮やかな配色で元気いっぱいの仕上がり"
                        },
                        {
                            "label": "リアル寄り",
                            "value": "realistic",
                            "icon": "Maximize2",
                            "description": "写真に近い質感で描き込むスタイル"
                        },
                        {
                            "label": "アニメ・デフォルメ",
                            "value": "anime",
                            "icon": "Smile",
                            "description": "デフォルメされた可愛らしいアニメ風タッチ"
                        },
                        {
                            "label": "線画シンプル",
                            "value": "lineart",
                            "icon": "CircleDashed",
                            "description": "シンプルな線画。グッズ映えするスタイル"
                        }
                    ],
                    "required": true,
                    "hint": "グッズにするなら「線画シンプル」や「ポップ」が映えます。飾る用なら「水彩」や「リアル寄り」がおすすめ"
                },
                {
                    "id": "pet_name",
                    "label": "ペットのお名前",
                    "type": "text",
                    "required": true,
                    "hint": "イラストやグッズにお名前を入れることもできます"
                },
                {
                    "id": "pet_features",
                    "label": "ペットの特徴（毛色・模様・チャームポイントなど）",
                    "type": "text",
                    "required": false,
                    "hint": "例：「左耳だけ茶色」「鼻の横にほくろ」「しっぽがくるんと丸い」など、写真ではわかりにくい特徴も教えてください"
                },
                {
                    "id": "style_note",
                    "label": "画風に関するご要望（任意）",
                    "type": "text",
                    "required": false,
                    "hint": "例：「お花に囲まれた感じで」「おもちゃで遊んでるポーズ」「家族の手と一緒に」など"
                }
            ]
        },
        {
            "step": 3,
            "id": "step_goods",
            "name": "グッズ選択",
            "type": "product_selection",
            "requires": ["tier"]
        },
        {
            "step": 4,
            "id": "step_customer",
            "name": "お客様情報",
            "type": "customer_info",
            "fields": [
                {
                    "id": "name",
                    "label": "お名前",
                    "type": "text",
                    "required": true
                },
                {
                    "id": "email",
                    "label": "メールアドレス",
                    "type": "email",
                    "required": true
                },
                {
                    "id": "shipping_address",
                    "label": "お届け先住所（グッズの場合）",
                    "type": "text",
                    "required": false
                },
                {
                    "id": "delivery_date",
                    "label": "納品希望日（任意）",
                    "type": "date",
                    "required": false
                }
            ]
        },
        {
            "step": 5,
            "id": "step_usage",
            "name": "ご利用規約",
            "type": "agreements",
            "fields": [
                {
                    "id": "usage_type",
                    "label": "利用用途",
                    "type": "select",
                    "options": [
                        {
                            "label": "個人利用",
                            "value": "personal",
                            "icon": "User"
                        },
                        {
                            "label": "商用利用",
                            "value": "commercial",
                            "icon": "Briefcase"
                        }
                    ],
                    "required": true
                }
            ],
            "consentRequired": [
                "無料修正は1回までとなります",
                "大幅な構図変更や書き直しは追加料金が発生します",
                "デジタル商品の性質上、制作開始後のキャンセル・返金はできません",
                "グッズは発送後の返品・交換はできません",
                "連絡やファイルのやり取りは専用のプロジェクトルームで行います"
            ]
        },
        {
            "step": 6,
            "id": "step_confirm",
            "name": "注文確認",
            "type": "confirmation"
        }
    ],
    "workflow": {
        "onPaymentSuccess": [
            "CREATE_PROJECT_RECORD",
            "GENERATE_CLIENT_PORTAL",
            "SEND_CUSTOMER_CONFIRMATION_EMAIL",
            "NOTIFY_CREATOR_NEW_ORDER"
        ],
        "onDelivery": [
            "TAG_MAILING_LIST"
        ]
    },
    "projectStatuses": [
        "NEW",
        "WAITING_ASSETS",
        "IN_PRODUCTION",
        "REVIEW",
        "DELIVERED",
        "CLOSED"
    ],
    "mailingListTagsTemplate": [
        "pet_illustration",
        "{{tier.id}}",
        "{{art_style}}",
        "{{commercial_use}}"
    ]
}