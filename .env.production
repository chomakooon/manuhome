# 本番ビルド用の環境変数オーバーライド
#
# OpenRouter APIキーは「フロントに埋め込まず」サーバー(Supabase Edge Function)経由にするため、
# 本番ビルドでは必ず空にする。これにより src/lib/gemini.js は自動で Edge Function 経由になり、
# AIチャット(AiChatWidget/AiAssistant)も ai-chat Edge Function 経由で動作する。
# 絶対にここに sk-or-v1... を書かないこと（書くとJSバンドルに露出する）。
VITE_OPENROUTER_API_KEY=

# 下記の本番値はビルド環境(GitHub Actions の Secrets → env)で注入する想定。
# ローカルで本番相当ビルドを試す場合のみ、ここに本番公開キーを入れてもよい（pk_live/anon は公開前提のキー）。
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
