# 本番ビルド用の環境変数（npm run build 時に .env より優先）
#
# OpenRouter APIキーは「フロントに埋め込まず」サーバー(Supabase Edge Function)経由にするため、
# 本番ビルドでは必ず空にする。これにより gemini.js は自動で Edge Function 経由になる。
# 絶対にここに sk-or-v1... を書かないこと（書くとJSバンドルに露出する）。
VITE_OPENROUTER_API_KEY=

# Supabase（anon/URLは公開前提のキー。Edge FunctionのJWT検証を通すためJWT形式anon keyを使用）
VITE_SUPABASE_URL=https://nhktlafexurxzzbitvjy.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5oa3RsYWZleHVyeHp6Yml0dmp5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAxMTc4MDMsImV4cCI6MjA5NTY5MzgwM30.yzADmxc4jzmo0ip69ZTyizD55o6PSDcFchlMEE0ot6w

# Stripe（本番審査中。pk_は公開可。テスト/本番キー取得後に設定すると決済が有効化される）
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
